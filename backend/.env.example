# ART JOURNEYS — backend environment
PORT=8080
APP_ENV=development

# PostgreSQL
DATABASE_URL=postgres://artjourneys:artjourneys@localhost:5432/artjourneys?sslmode=disable

# Redis (optional — leave empty to disable caching)
REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# SMTP (optional — leave SMTP_HOST empty to log emails instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@artjourneys.travel

# Inbox that receives new inquiry notifications
MAIL_TO=studio@artjourneys.travel
