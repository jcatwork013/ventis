# ART JOURNEYS — backend production environment (api-ventis.9bricks.com)
PORT=8080
APP_ENV=production

# Managed PostgreSQL (Neon / Supabase / RDS). Keep sslmode=require in production.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/artjourneys?sslmode=require

# Managed Redis (optional but recommended)
REDIS_URL=rediss://USER:PASSWORD@HOST:6379/0

# CORS — only the production frontend origin is allowed
ALLOWED_ORIGINS=https://ventis.9bricks.com

# Transactional email (e.g. Postmark / SES / Resend SMTP)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ventis.9bricks.com

# Inbox that receives new inquiry notifications
MAIL_TO=studio@9bricks.com
