# ART JOURNEYS — frontend production environment (ventis.9bricks.com)

# Public site URL — used for metadata, OpenGraph, sitemap, robots
NEXT_PUBLIC_SITE_URL=https://ventis.9bricks.com

# Backend API base URL reachable from the browser (build-time inlined).
# Single-level subdomain (dash, not dot) so Cloudflare Universal SSL (*.9bricks.com) covers it.
NEXT_PUBLIC_API_URL=https://api-ventis.9bricks.com

# Optional: server-side fetch URL if the API is reachable on a private network.
# When the API is public, leave this equal to NEXT_PUBLIC_API_URL or unset.
# API_INTERNAL_URL=https://api-ventis.9bricks.com
